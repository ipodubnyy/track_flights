# FlightAPI.io
FLIGHTAPI_KEY=your_flightapi_key

# Grok (xAI) API
GROK_API_KEY=your_grok_api_key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Google OAuth2 (console.cloud.google.com -> Credentials -> OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
SECRET_KEY=change-me-to-a-random-secret
ALLOWED_EMAILS=  # comma-separated; empty = allow all Google accounts

# App settings
DATABASE_URL=sqlite:///./track_flights.db
CHECK_INTERVAL_HOURS=6
